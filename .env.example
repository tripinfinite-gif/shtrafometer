# ─── Auth ───────────────────────────────────────────────────────
SESSION_SECRET="random-secret-min-32-chars"
ADMIN_PASSWORD_HASH_B64="base64-encoded-bcrypt-hash"

# ─── YooKassa (payments) ────────────────────────────────────────
