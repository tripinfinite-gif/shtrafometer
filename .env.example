# ─── Database (PostgreSQL) ──────────────────────────────────────
DATABASE_URL="postgresql://shtrafometer:password@shtrafometer-postgres:5432/shtrafometer"
DATABASE_SSL="false"

# ─── Auth ───────────────────────────────────────────────────────
SESSION_SECRET="random-secret-min-32-chars"
ADMIN_PASSWORD_HASH_B64="base64-encoded-bcrypt-hash"

# ─── YooKassa (payments) ────────────────────────────────────────
YOOKASSA_SHOP_ID="your-shop-id"
YOOKASSA_SECRET_KEY="your-secret-key"

# ─── SMTP (Yandex 360) ─────────────────────────────────────────
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT="465"
SMTP_USER="noreply@shtrafometer.ru"
SMTP_PASS="пароль-приложения-из-яндекс-360"
FROM_EMAIL="Штрафометр <noreply@shtrafometer.ru>"
ADMIN_EMAIL="info@shtrafometer.ru"

# ─── AI Consultant (v2.2-ai) ────────────────────────────────────
# См. docs/plan-ai-consultant.md → раздел "Env matrix".
# Валидация ленивая (src/lib/env.ts) — отсутствие ключей не ломает
# `pnpm build` и `pnpm dev`. Ошибка возникает только при первом
# обращении к соответствующему AI-функционалу из admin/ai-consultant.

# Phase 2 — LLM провайдеры (обязательны для запуска чата)
OPENAI_API_KEY="sk-proj-..."
ANTHROPIC_API_KEY="sk-ant-..."
YANDEX_GPT_API_KEY="AQVN..."
YANDEX_GPT_FOLDER_ID="b1g..."

# Phase 3 — Yandex OAuth + шифрование токенов клиентов
# OAuth-приложение: https://oauth.yandex.ru/client/new
YANDEX_DIRECT_CLIENT_ID=""
YANDEX_DIRECT_CLIENT_SECRET=""
# Должен совпадать с redirect URI в OAuth-приложении
YANDEX_DIRECT_REDIRECT_URI="https://shtrafometer.ru/api/admin/ai/oauth/yandex/callback"
# Ключ для pgcrypto-шифрования OAuth-токенов клиентов (>=32 случайных байта).
# Сгенерировать: openssl rand -base64 48
# ВНИМАНИЕ: ротация ключа требует перешифровки всех токенов в БД.
AI_TOKEN_ENCRYPTION_KEY=""

# Phase 4 — self-hosted эмбеддинги (multilingual-e5-large в Docker)
# Внутри docker-compose: http://embeddings:8000
EMBEDDINGS_SERVICE_URL="http://localhost:8000"

# Опциональные настройки (с дефолтами)
# AI_ROUTER_MODE: auto | openai-only | claude-only | yandexgpt-only (default: auto)
AI_ROUTER_MODE="auto"
# Лимит запросов к AI-чату в час на пользователя (default: 60)
AI_RATE_LIMIT_PER_HOUR="60"
